root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Swift follows Apple's 4-space convention; C and friends use the 2-space LLVM
# default above, matching .clang-format.
[*.swift]
indent_size = 4

[Makefile]
indent_style = tab
